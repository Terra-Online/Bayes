{
  "name": "bayes-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "dev:local": "cp .dev.vars.local .dev.vars && wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate:remote": "wrangler d1 migrations apply DB --remote"
  },
  "dependencies": {
    "@upstash/redis": "^1.35.3",
    "better-auth": "^1.6.0",
    "hono": "^4.7.7",
    "nanoid": "^5.1.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260404.0",
    "@eslint/js": "^9.24.0",
    "@types/node": "^22.15.3",
    "@typescript-eslint/parser": "^8.46.1",
    "eslint": "^9.24.0",
    "typescript": "^5.8.3",
    "wrangler": "^4.10.0"
  },
  "engines": {
    "node": ">=20"
  }
}
